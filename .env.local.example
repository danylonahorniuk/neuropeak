# Telegram Bot credentials — required for leads to be sent to Telegram.
# Create a bot at @BotFather, copy the token here.
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID. Start a chat with @userinfobot to get your personal ID,
# or add your bot to a group and use the group's chat ID (usually starts with -100).
TELEGRAM_CHAT_ID=

# Optional: Google Apps Script web-app URL for logging leads to Google Sheets.
# Leave empty to skip Sheets integration. See README for setup steps.
GOOGLE_SHEETS_WEB_APP_URL=
